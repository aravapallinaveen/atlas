# Copy to .env and fill in. These are PUBLIC front-end values (safe to expose in the
# browser bundle) — never put the Butterbase secret key (bb_sk_...) here.

# Butterbase app the front-end talks to.
VITE_API_URL=https://api.butterbase.ai
VITE_APP_ID=app_xxxxxxxxxxxx

# Use the built-in mock backend instead of Butterbase (offline dev / no account).
#   false -> call the deployed Butterbase functions (default)
#   true  -> use in-app canned data
VITE_USE_MOCK=false

# Which backend the agent reasoning step runs on.
#   gateway    -> Butterbase AI gateway (Phase 1)
#   rocketride -> RocketRide Cloud pipeline (Phase 2)
VITE_AGENT_BACKEND=gateway
